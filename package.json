{
  "name": "commandsuite-docs",
  "version": "0.0.0",
  "private": true,
  "description": "Docs site for CommandSuite — Astro app serving docs.commandsuite.io. Content is synced at build time from the OSS repo's docs/ tree.",
  "license": "Apache-2.0",
  "author": "Andrew Jon Przybilla <andrewjon@efficacious.io>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-efficacious/commandsuite-docs.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "sync-docs": "node scripts/sync-oss-docs.mjs",
    "dev": "pnpm sync-docs && astro dev --port 4322",
    "build": "pnpm sync-docs && astro build",
    "preview": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/mdx": "^4.0.0",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.6.0",
    "wrangler": "^4.84.1"
  }
}
